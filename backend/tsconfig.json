{
  "compilerOptions": {
    "types": ["node"],
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "build",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "useUnknownInCatchVariables": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "build", "old-project-files-delete"]
}
