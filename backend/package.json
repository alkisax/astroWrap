{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "copyfiles src/**/*.yml build/",
    "dev": "ts-node-dev src/server.ts",
    "dev:test": "cross-env NODE_ENV=test ts-node-dev src/server.ts",
    "lint": "eslint src/**/*.{js,jsx,ts,tsx} --ignore-pattern build --ignore-pattern dist",
    "start": "node build/src/server.js",
    "test": "cross-env NODE_ENV=test jest --coverage --testTimeout=50000 --runInBand --verbose  --silent --resetModules --clearMocks",
    "test:log": "cross-env NODE_ENV=test jest --coverage --testTimeout=50000 --runInBand --verbose --resetModules --clearMocks"
  },
  "keywords": [],
  "author": "alkisax",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "circular-natal-horoscope-js": "^1.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.2",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "ts-node-dev": "^2.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/swagger-jsdoc": "^6.0.4"
  }
}
